rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: transactions
    // Fields: description (string), amount (number), type (string), category (string), date (string), userId (string)
    //
    // Collection: partners
    // Fields: name (string), role (string), commissionRate (number), email (string), phone (string), userId (string)
    //
    // Collection: commissions
    // Fields: partnerId (string), transactionId (string), amount (number), status (string), date (string), userId (string)
    //
    // Collection: appointments
    // Fields: clientName (string), service (string), price (number), time (string), status (string), userId (string)
    //
    // Collection: goals
    // Fields: name (string), target_amount (number), current_amount (number), target_date (string), category (string), notes (string), userId (string)
    //
    // Collection: serviceCosts
    // Fields: name (string), materialCost (number), energyCost (number), timeInMinutes (number), hourlyRate (number), currentPrice (number), userId (string)
    //
    // Collection: weddingGoals
    // Fields: target (number), current (number), monthlyAporte (number), userId (string)
    //
    // Collection: onboarding
    // Document ID: userId
    // Fields: name (string), companyName (string), photoURL (string), primaryColor (string), revenueGoal (number), proLabore (number), expenseAlertThreshold (number), mainService (string), hasPartners (bool), weddingGoalAmount (number, optional), weddingDate (string, optional), dataEntryMethod (string), onboardingCompleted (bool), userId (string)
    //
    // Collection: fixedCosts
    // Fields: name (string), category (string), amount (number), due_day (number), is_active (bool), notes (string), userId (string)
    //
    // Collection: meiObligations
    // Fields: name (string), type (string), amount (number), due_date (string), status (string), reference_month (string), notes (string), userId (string)
    //
    // Collection: bank_accounts
    // Fields: bankName (string), accountType (string), balance (number), currency (string), lastSync (string), institutionId (string), userId (string), status (string)
    //
    // Collection: bank_transactions
    // Fields: bankAccountId (string), description (string), amount (number), date (string), category (string), type (string), userId (string)
    //
    // Collection: users
    // Document ID: userId
    // Fields: email (string), displayName (string), photoURL (string), role (string), status (string), blockedFeatures (list), lastLogin (string), createdAt (string), isBlocked (bool), blockMessage (string), blockReason (string), metadata (map)
    //
    // Collection: app_config
    // Document ID: global
    // Fields: maintenanceMode (bool), globalMessage (string), topBanner (map), featureFlags (map)
    //
    // Collection: audit_logs
    // Fields: action (string), details (map), userId (string), userEmail (string), timestamp (string)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email == "jonathastdsantos@gmail.com" && request.auth.token.email_verified == true) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isMasterAdmin() {
      return isAuthenticated() && request.auth.token.email == "jonathastdsantos@gmail.com" && request.auth.token.email_verified == true;
    }

    // Basic rules for all collections
    match /transactions/{id} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }
    match /goals/{id} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }
    match /serviceCosts/{id} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }
    match /weddingGoals/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    match /onboarding/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    match /fixedCosts/{id} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }
    match /meiObligations/{id} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }
    match /bank_accounts/{id} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }
    match /bank_transactions/{id} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }
    match /users/{userId} {
      allow list: if isAdmin();
      allow get: if isOwner(userId) || isAdmin();
      
      allow create: if isMasterAdmin() || 
                    (isOwner(userId) && request.resource.data.role == 'user') ||
                    isAdmin();
                    
      allow update: if isMasterAdmin() || 
                    (isOwner(userId) && request.resource.data.role == resource.data.role && !(request.resource.data.keys().hasAny(['isBlocked'])) && !(request.resource.data.keys().hasAny(['role']))) ||
                    isAdmin();
      
      allow delete: if isAdmin();
    }
    match /audit_logs/{id} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }
    match /partners/{id} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }
    match /app_config/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /plans/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /commissions/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && 
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.partnerId is string &&
                    request.resource.data.amount is number &&
                    (request.resource.data.status == 'pending' || request.resource.data.status == 'paid' || request.resource.data.status == 'pendente' || request.resource.data.status == 'pago');
      allow update: if isAuthenticated() && 
                    resource.data.userId == request.auth.uid && 
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.amount is number &&
                    (request.resource.data.status == 'pending' || request.resource.data.status == 'paid' || request.resource.data.status == 'pendente' || request.resource.data.status == 'pago');
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
    match /appointments/{id} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && 
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.clientName is string &&
                    request.resource.data.price is number &&
                    (request.resource.data.status == 'scheduled' || request.resource.data.status == 'completed' || request.resource.data.status == 'cancelled' || request.resource.data.status == 'agendado' || request.resource.data.status == 'concluido' || request.resource.data.status == 'cancelado');
      allow update: if isAuthenticated() && 
                    resource.data.userId == request.auth.uid && 
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.price is number &&
                    (request.resource.data.status == 'scheduled' || request.resource.data.status == 'completed' || request.resource.data.status == 'cancelled' || request.resource.data.status == 'agendado' || request.resource.data.status == 'concluido' || request.resource.data.status == 'cancelado');
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
